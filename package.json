    "configuration": {
      "title": "Code Alignment",
      "properties": {
        "codealignment.alignments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "delimiter": {
                "type": "string",
                "title": "Delimiter",
                "description": "The delimiter string to align by. Position in array determines #N: first item = #1, second = #2, etc. When set to '(', both '(' and ')' are aligned automatically."
              },
              "submenu": {
                "type": "boolean",
                "title": "Submenu",
                "description": "When true, this item appears in the 'More Alignments' submenu instead of the main right-click menu. Helps keep the menu compact.",
                "default": false
              }
            }
          },
          "default": [
            {
              "delimiter": "("
            },
            {
              "delimiter": ";"
            },
            {
              "delimiter": ","
            },
            {
              "delimiter": "."
            },
            {
              "delimiter": "="
            },
            {
              "delimiter": "<=",
              "submenu": true
            },
            {
              "delimiter": "//",
              "submenu": true
            },
            {
              "delimiter": "[",
              "submenu": true
            },
            {
              "delimiter": "]",
              "submenu": true
            },
            {
              "delimiter": "reg",
              "submenu": true
            },
            {
              "delimiter": "wire",
              "submenu": true
            },
            {
              "delimiter": "input",
              "submenu": true
            },
            {
              "delimiter": "output",
              "submenu": true
            }
          ],
          "description": "Alignment delimiter list (up to 15 items). Each item's position determines its #N number: item[0] → #1, item[1] → #2, etc. This #N appears in the right-click menu for easy cross-reference. The first 9 items are also bound to keyboard shortcuts Ctrl+Shift+1~9. When delimiter is '(', both '(' and ')' are aligned together. Set 'submenu: true' on an item to fold it into the 'More Alignments' submenu."
        },
        "codealignment.xmlTypes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".xml",
            ".xaml",
            ".cshtml",
            ".aspx",
            ".ascx",
            ".master",
            ".html",
            ".htm",
            ".svg",
            ".xslt",
            ".config",
            ".resx",
            ".targets",
            ".xul",
            ".vcproj",
            ".csproj",
            ".vbproj"
          ],
          "description": "File types to treat as XML (use XML scope selector for alignment)."
        },
        "codealignment.vlTypes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".v",
            ".sv",
            ".vh",
            ".svh",
            ".vhd",
            ".svp"
          ],
          "description": "Verilog/SystemVerilog file extensions. These files will use the Verilog scope selector for smart block-boundary detection."
        },
        "codealignment.scopeSelectorLineValues": {
          "type": "string",
          "default": "",
          "description": "Space-separated values that match blank lines for scope selection."
        },
        "codealignment.scopeSelectorLineEnds": {
          "type": "string",
          "default": "",
          "description": "Space-separated patterns that match line endings for scope selection."
        },
        "codealignment.useIdeTabSettings": {
          "type": "boolean",
          "default": true,
          "description": "Use the IDE tab settings (tab size, insert spaces) when performing alignments."
        }
      }
    }
