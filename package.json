{
  "name": "codealignment",
  "displayName": "Code Alignment",
  "description": "JSON 配置驱动的代码对齐工具。在 settings.json 中自定义对齐分隔符，右键菜单实时同步更新。支持子菜单折叠（submenu: true）、Ctrl+Shift+1~9 快捷键、一键括号对齐、逗号和句点对齐、Verilog/SystemVerilog 端口对齐。",
  "version": "2.0.1",
  "publisher": "codealignment",
  "repository": {
    "type": "git",
    "url": "https://github.com/yangleiyu/codealignment-2.0.1.git"
  },
  "homepage": "https://github.com/yangleiyu/codealignment-2.0.1",
  "bugs": {
    "url": "https://github.com/yangleiyu/codealignment-2.0.1/issues"
  },
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Formatters",
    "Other"
  ],
  "keywords": [
    "align",
    "alignment",
    "formatting",
    "code alignment",
    "json config",
    "verilog",
    "systemverilog",
    "hdl",
    "customizable"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "submenus": [
      {
        "id": "codealignment.alignSubmenu",
        "label": "More Alignments"
      }
    ],
    "commands": [
      {
        "command": "codealignment.alignItem0",
        "title": "#1  Align by ( )",
        "icon": "$(bracket)"
      },
      {
        "command": "codealignment.alignItem1",
        "title": "#2  Align by ;",
        "icon": "$(symbol-semicolon)"
      },
      {
        "command": "codealignment.alignItem2",
        "title": "#3  Align by ,",
        "icon": "$(symbol-misc)"
      },
      {
        "command": "codealignment.alignItem3",
        "title": "#4  Align by .",
        "icon": "$(symbol-misc)"
      },
      {
        "command": "codealignment.alignItem4",
        "title": "#5  Align by =",
        "icon": "$(symbol-operator)"
      },
      {
        "command": "codealignment.alignItem5",
        "title": "#6  Align by <=",
        "icon": "$(symbol-operator)"
      },
      {
        "command": "codealignment.alignItem6",
        "title": "#7  Align by //",
        "icon": "$(comment)"
      },
      {
        "command": "codealignment.alignItem7",
        "title": "#8  Align by [",
        "icon": "$(bracket)"
      },
      {
        "command": "codealignment.alignItem8",
        "title": "#9  Align by ]",
        "icon": "$(bracket)"
      },
      {
        "command": "codealignment.alignItem9",
        "title": "#10 Align by reg",
        "icon": "$(symbol-keyword)"
      },
      {
        "command": "codealignment.alignItem10",
        "title": "#11 Align by wire",
        "icon": "$(symbol-keyword)"
      },
      {
        "command": "codealignment.alignItem11",
        "title": "#12 Align by input",
        "icon": "$(symbol-interface)"
      },
      {
        "command": "codealignment.alignItem12",
        "title": "#13 Align by output",
        "icon": "$(symbol-interface)"
      },
      {
        "command": "codealignment.alignItem13",
        "title": "#14 Align (custom)",
        "icon": "$(symbol-misc)"
      },
      {
        "command": "codealignment.alignItem14",
        "title": "#15 Align (custom)",
        "icon": "$(symbol-misc)"
      },
      {
        "command": "codealignment.customAlign",
        "title": "Align by Custom Delimiter...",
        "icon": "$(edit)"
      },
      {
        "command": "codealignment.configureAlignments",
        "title": "Configure Alignments...",
        "icon": "$(gear)"
      },
      {
        "command": "codealignment.restoreDefaultAlignments",
        "title": "Restore Default Alignments",
        "icon": "$(debug-restart)"
      }
    ],
    "keybindings": [
      {
        "command": "codealignment.alignItem0",
        "key": "ctrl+shift+1",
        "when": "editorTextFocus && codealignment.hasAlignItem0"
      },
      {
        "command": "codealignment.alignItem1",
        "key": "ctrl+shift+2",
        "when": "editorTextFocus && codealignment.hasAlignItem1"
      },
      {
        "command": "codealignment.alignItem2",
        "key": "ctrl+shift+3",
